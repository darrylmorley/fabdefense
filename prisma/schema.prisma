generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "nativeDistinct", "relationJoins", "typedSql"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id                  Int                  @id @default(autoincrement())
  lightspeedID        Int                  @unique @map("lightspeed_id")
  name                String               @map("name")
  fullPathName        String               @map("full_path_name")
  parentID            Int?                 @map("parent_id")
  nodeDepth           Int?                 @map("node_depth")
  leftNode            Int?                 @map("left_node")
  rightNode           Int?                 @map("right_node")
  description         String?              @map("description")
  slug                String               @unique @map("slug")
  metaTitle           String?              @map("meta_title")
  metaDescription     String?              @map("meta_description")
  imageURL            String?              @map("image_url")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  lightspeedCreatedAt DateTime?            @map("lightspeed_created_at")
  lightspeedUpdatedAt DateTime?            @map("lightspeed_updated_at")
  spec_type           SpecType             @default(STANDARD)
  category_intro      String?
  categories          categories?          @relation("categoriesTocategories", fields: [parentID], references: [lightspeedID])
  other_categories    categories[]         @relation("categoriesTocategories")
  category_change_log categoryChangeLog[]
  category_overrides  category_overrides[]
  faq                 faq[]
  matrixProducts      matrixProducts[]
  products            products[]
  videos              videos[]

  @@index([name])
  @@index([parentID])
  @@index([lightspeedID])
  @@index([slug])
}

model manufacturers {
  id                      Int                      @id @default(autoincrement())
  lightspeedID            Int                      @unique @map("lightspeed_id")
  name                    String                   @map("name")
  description             String?                  @map("description")
  slug                    String                   @unique @map("slug")
  metaTitle               String?                  @map("meta_title")
  metaDescription         String?                  @map("meta_description")
  imageURL                String?                  @map("image_url")
  lightspeedCreatedAt     DateTime?                @map("lightspeed_created_at")
  lightspeedUpdatedAt     DateTime?                @map("lightspeed_updated_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  websiteURL              String?                  @map("website_url")
  faq                     faq[]
  manufacturer_change_log manufacturerChangeLog[]
  manufacturer_overrides  manufacturer_overrides[]
  matrixProducts          matrixProducts[]
  products                products[]
  videos                  videos[]

  @@index([name])
  @@index([slug])
  @@index([lightspeedID])
  @@index([imageURL])
}

model customers {
  id                      String                    @id @default(uuid())
  lightspeedID            Int                       @unique @map("lightspeed_id")
  googleID                String?                   @unique @map("google_id")
  firstName               String?                   @map("first_name")
  lastName                String?                   @map("last_name")
  email                   String?                   @unique @map("email")
  lightspeedCreatedAt     DateTime?                 @map("lightspeed_created_at")
  lightspeedUpdatedAt     DateTime?                 @map("lightspeed_updated_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @default(now()) @updatedAt @map("updated_at")
  customerType            CustomerType              @default(NONE) @map("customer_type")
  archived                Boolean                   @default(false)
  address1                String?                   @map("address1")
  address2                String?                   @map("address2")
  city                    String?                   @map("city")
  country                 String?                   @map("country")
  state                   String?                   @map("state")
  zip                     String?                   @map("zip")
  tel                     String?                   @map("tel")
  carts                   carts[]
  contactSubmissions      contactSubmissions[]
  creditAccounts          creditAccounts[]
  financeApplications     financeApplications[]
  restockNotifications    restockNotifications[]
  reviews                 reviews[]
  saleLines               saleLines[]
  sales                   sales[]
  web_gift_card_purchases web_gift_card_purchases[]

  @@index([email])
  @@index([googleID])
  @@index([lightspeedID])
}

model products {
  id                   Int                      @id @default(autoincrement())
  lightspeedID         Int                      @unique @map("lightspeed_id")
  matrixID             Int?                     @map("matrix_id")
  sku                  String?                  @map("sku")
  manufacturerSku      String?                  @map("manufacturer_sku")
  gtin                 String?                  @map("gtin")
  name                 String                   @map("name")
  qoh                  Int                      @default(0) @map("qoh")
  price                Float                    @map("price")
  salePrice            Float                    @map("sale_price")
  onSale               Boolean?                 @default(false) @map("on_sale")
  isFeatured           Boolean?                 @default(false) @map("is_featured")
  isOnBackorder        Boolean?                 @default(false) @map("is_on_backorder")
  backorderQty         Int?                     @map("backorder_qty")
  reorderLevel         Int?                     @map("reorder_level")
  reorderPoint         Int?                     @map("reorder_point")
  shortDescription     String?                  @map("short_description")
  longDescription      String?                  @map("long_description")
  categoryID           Int?                     @map("category_id")
  manufacturerID       Int?                     @map("manufacturer_id")
  colour               String?                  @map("colour")
  size                 String?                  @map("size")
  width                String?                  @map("width")
  height               String?                  @map("height")
  length               String?                  @map("length")
  weight               String?                  @map("weight")
  metaTitle            String?                  @map("meta_title")
  metaDescription      String?                  @map("meta_description")
  isPreorder           Boolean?                 @default(false) @map("is_preorder")
  preOrderQty          Int?                     @map("pre_order_qty")
  slug                 String?                  @unique @map("slug")
  lightspeedCreatedAt  DateTime?                @map("lightspeed_created_at")
  lightspeedUpdatedAt  DateTime?                @map("lightspeed_updated_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @default(now()) @updatedAt @map("updated_at")
  archived             Boolean?                 @default(false) @map("archived")
  black_friday_sale    Boolean?                 @default(false)
  sex                  ClothingSex?
  search_vector        Unsupported("tsvector")? @default(dbgenerated("''::tsvector"))
  cartItem             cartItem[]
  faq                  faq[]
  images               images[]
  orderLines           orderLines[]
  product_change_log   productChangeLog[]
  productOverride      productOverride[]
  product_slug_history product_slug_history[]
  categories           categories?              @relation(fields: [categoryID], references: [lightspeedID])
  manufacturers        manufacturers?           @relation(fields: [manufacturerID], references: [lightspeedID])
  matrixProducts       matrixProducts?          @relation(fields: [matrixID], references: [lightspeedID])
  restockNotifications restockNotifications[]
  reviews              reviews[]
  saleLines            saleLines[]
  specs_ammo           specs_ammo?
  specs_clothing       specs_clothing?
  specs_firearms       specs_firearms?
  specs_footwear       specs_footwear?
  specs_moderators     specs_moderators?
  specs_optics         specs_optics?
  specs_thermal        specs_thermal?
  videos               videos[]

  @@index([categoryID])
  @@index([manufacturerID])
  @@index([matrixID])
  @@index([name])
  @@index([slug])
  @@index([lightspeedID])
  @@index([sku])
  @@index([qoh])
  @@index([onSale])
  @@index([isFeatured])
  @@index([black_friday_sale])
  @@index([search_vector], map: "idx_products_search_vector", type: Gin)
}

model productOverride {
  id               String   @id @default(uuid()) @map("id")
  productID        Int      @map("product_id")
  siteSlug         String   @map("site_slug")
  title            String?  @map("title")
  shortDescription String?  @map("short_description")
  longDescription  String?  @map("long_description")
  metaTitle        String?  @map("meta_title")
  metaDescription  String?  @map("meta_description")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  product          products @relation(fields: [productID], references: [lightspeedID], onDelete: Cascade)

  @@unique([productID, siteSlug])
  @@index([productID])
  @@index([siteSlug])
  @@map("product_overrides")
}

model matrixProducts {
  id                  Int            @id @default(autoincrement())
  lightspeedID        Int            @unique @map("lightspeed_id")
  name                String         @map("name")
  categoryID          Int?           @map("category_id")
  manufacturerID      Int?           @map("manufacturer_id")
  ItemAttributeSet    Json?          @map("item_attribute_set")
  price               Float          @map("price")
  salePrice           Float          @map("sale_price")
  shortDescription    String?        @map("short_description")
  longDescription     String?        @map("long_description")
  slug                String?        @unique @map("slug")
  metaTitle           String?        @map("meta_title")
  metaDescription     String?        @map("meta_description")
  lightspeedUpdatedAt DateTime?      @map("lightspeed_updated_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at")
  archived            Boolean?       @default(false) @map("archived")
  images              images[]
  categories          categories?    @relation(fields: [categoryID], references: [lightspeedID])
  manufacturers       manufacturers? @relation(fields: [manufacturerID], references: [lightspeedID])
  products            products[]

  @@index([categoryID])
  @@index([manufacturerID])
  @@index([name])
  @@index([slug])
  @@index([lightspeedID])
  @@map("matrix_products")
}

model carts {
  id                  String                @id @default(uuid())
  lightspeedID        Int?                  @unique @map("lightspeed_id")
  customerID          Int?                  @map("customer_id")
  sessionToken        String?               @unique @map("session_token")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")
  completed           Boolean               @default(false) @map("completed")
  cancelled           Boolean               @default(false) @map("cancelled")
  website             Website
  cartItems           cartItem[]
  customer            customers?            @relation(fields: [customerID], references: [lightspeedID])
  financeApplications financeApplications[]
  sales               sales[]

  @@index([customerID])
  @@index([sessionToken])
  @@index([completed])
  @@index([cancelled])
}

model cartItem {
  id           String    @id @default(uuid())
  lightspeedID Int?      @map("lightspeed_id")
  cartID       String    @map("cart_id")
  quantity     Int       @default(1) @map("quantity")
  price        Float     @map("price")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  cart         carts     @relation(fields: [cartID], references: [id], onDelete: Cascade)
  product      products? @relation(fields: [lightspeedID], references: [lightspeedID])

  @@index([cartID])
  @@index([lightspeedID])
  @@map("cart_items")
}

model financeApplications {
  id                String                   @id @default(cuid())
  cartID            String?                  @map("cart_id")
  lightspeedCartID  Int?                     @map("lightspeed_cart_id")
  customerID        Int?                     @map("customer_id")
  status            FinanceApplicationStatus @default(PENDING)
  customerEmail     String                   @map("customer_email")
  customerPhone     String                   @map("customer_phone")
  submittedAt       DateTime                 @default(now()) @map("submitted_at")
  approvedAt        DateTime?                @map("approved_at")
  declinedAt        DateTime?                @map("declined_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  applicationRef    String                   @unique @default(cuid()) @map("application_ref")
  apr               Float                    @default(21.9)
  billingAddress1   String                   @map("billing_address1")
  billingAddress2   String?                  @map("billing_address2")
  billingCity       String                   @map("billing_city")
  billingCounty     String                   @map("billing_county")
  billingPostcode   String                   @map("billing_postcode")
  customerFirstName String                   @map("customer_first_name")
  customerLastName  String                   @map("customer_last_name")
  customerTitle     String?                  @map("customer_title")
  depositAmount     Float                    @map("deposit_amount")
  depositPercent    Int                      @map("deposit_percent")
  loanAmount        Float                    @map("loan_amount")
  monthlyPayment    Float                    @map("monthly_payment")
  orderAmount       Float                    @map("order_amount")
  reviewedAt        DateTime?                @map("reviewed_at")
  termMonths        Int                      @map("term_months")
  totalInterest     Float                    @map("total_interest")
  totalRepayable    Float                    @map("total_repayable")
  carts             carts?                   @relation(fields: [cartID], references: [id])
  customers         customers?               @relation(fields: [customerID], references: [lightspeedID])
  sales             sales[]

  @@index([cartID])
  @@index([applicationRef])
  @@index([customerID])
  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@map("finance_applications")
}

model sales {
  id                      String                   @id @default(uuid())
  lightspeedID            Int                      @unique @map("lightspeed_id")
  cartID                  String?                  @map("cart_id")
  customerID              Int?                     @map("customer_id")
  siteSlug                String?                  @map("site_slug")
  total                   Float                    @map("total")
  subtotal                Float?                   @map("subtotal")
  taxTotal                Float?                   @map("tax_total")
  discountTotal           Float?                   @map("discount_total")
  discountID              Int?                     @map("discount_id")
  completed               Boolean                  @default(false) @map("completed")
  archived                Boolean                  @default(false) @map("archived")
  voided                  Boolean                  @default(false) @map("voided")
  referenceNumber         String?                  @map("reference_number")
  employeeID              Int?                     @map("employee_id")
  shopID                  Int?                     @map("shop_id")
  registerID              Int?                     @map("register_id")
  lightspeedCreatedAt     DateTime?                @map("lightspeed_created_at")
  lightspeedUpdatedAt     DateTime?                @map("lightspeed_updated_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  completeTime            DateTime?                @map("complete_time")
  billingAddress          Json?                    @map("billing_address")
  guestEmail              String?                  @map("guest_email")
  guestFirstName          String?                  @map("guest_first_name")
  guestLastName           String?                  @map("guest_last_name")
  shippingAddress         Json?                    @map("shipping_address")
  finance_application_id  String?
  payment_type_id         String[]
  credit_account_id       Int?
  credit_accounts         creditAccounts?
  saleLines               saleLines[]
  cart                    carts?                   @relation(fields: [cartID], references: [id])
  customer                customers?               @relation(fields: [customerID], references: [lightspeedID])
  finance_applications    financeApplications?     @relation(fields: [finance_application_id], references: [id])
  web_gift_card_purchases web_gift_card_purchases?

  @@index([cartID])
  @@index([createdAt])
  @@index([customerID])
  @@index([lightspeedID])
  @@index([completed])
  @@index([employeeID])
  @@index([shopID])
  @@index([completeTime])
  @@index([payment_type_id], type: Gin)
  @@index([credit_account_id])
  @@map("sales")
}

model saleLines {
  id                      String     @id @default(uuid())
  saleID                  Int        @map("sale_id")
  discountID              Int?       @map("discount_id")
  unitPrice               Float      @map("unit_price")
  normalUnitPrice         Float?     @map("normal_unit_price")
  discountAmount          Float?     @map("discount_amount")
  discountPercent         Float?     @map("discount_percent")
  tax                     Boolean    @map("tax")
  parentSaleLineID        Int?       @map("original_sale_line_id")
  lightspeedCreatedAt     DateTime?  @map("lightspeed_created_at")
  lightspeedUpdatedAt     DateTime?  @map("lightspeed_updated_at")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @default(now()) @updatedAt @map("updated_at")
  avgCost                 Float?     @map("avg_cost")
  calcLineDiscount        Float?     @map("calc_line_discount")
  calcTotal               Float?     @map("calc_total")
  calcTransactionDiscount Float?     @map("calc_transaction_discount")
  customerID              Int?       @map("customer_id")
  employeeID              Int?       @map("employee_id")
  fifoCost                Float?     @map("fifo_cost")
  isLayaway               Boolean    @default(false) @map("is_layaway")
  isSpecialOrder          Boolean    @default(false) @map("is_special_order")
  isWorkorder             Boolean    @default(false) @map("is_workorder")
  itemID                  Int?       @map("item_id")
  unitQuantity            Int        @map("unit_quantity")
  lightspeedID            Int?       @unique @map("lightspeed_id")
  customer                customers? @relation(fields: [customerID], references: [lightspeedID])
  product                 products?  @relation(fields: [itemID], references: [lightspeedID])
  sale                    sales      @relation(fields: [saleID], references: [lightspeedID], onDelete: Cascade)

  @@index([itemID])
  @@index([saleID])
  @@index([lightspeedID])
  @@index([customerID])
  @@map("sale_lines")
}

model creditAccounts {
  id                      Int                      @id @default(autoincrement())
  lightspeedID            Int                      @unique @map("lightspeed_id")
  name                    String?
  code                    String?
  description             String?
  giftCard                Boolean                  @default(false) @map("gift_card")
  balance                 Float
  customerID              Int?                     @map("customer_id")
  archived                Boolean
  lightspeedUpdatedAt     DateTime?                @map("lightspeed_updated_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  purchase_sale_id        Int?                     @unique
  customer                customers?               @relation(fields: [customerID], references: [lightspeedID])
  sales                   sales?                   @relation(fields: [purchase_sale_id], references: [lightspeedID])
  web_gift_card_purchases web_gift_card_purchases?

  @@index([lightspeedID])
  @@index([code])
  @@index([giftCard])
  @@index([customerID])
  @@index([purchase_sale_id])
  @@map("credit_accounts")
}

model reviews {
  id         String    @id @default(uuid())
  itemID     Int       @map("item_id")
  customerID String    @map("customer_id")
  userEmail  String    @map("user_email")
  rating     Int       @map("rating")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  reviewText String?   @map("review_text")
  customers  customers @relation(fields: [customerID], references: [id])
  products   products  @relation(fields: [itemID], references: [lightspeedID])

  @@index([itemID])
  @@index([rating])
  @@index([userEmail])
  @@index([createdAt])
  @@index([customerID])
}

model contactSubmissions {
  id          String     @id @default(cuid())
  name        String
  email       String
  message     String
  customerID  Int?       @map("customer_id")
  ipAddress   String?    @map("ip_address")
  userAgent   String?    @map("user_agent")
  status      String     @default("new")
  priority    String     @default("normal")
  category    String?
  adminNotes  String?    @map("admin_notes")
  respondedAt DateTime?  @map("responded_at")
  resolvedAt  DateTime?  @map("resolved_at")
  emailSent   Boolean    @default(false) @map("email_sent")
  emailError  String?    @map("email_error")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @default(now()) @map("updated_at")
  customers   customers? @relation(fields: [customerID], references: [lightspeedID])

  @@index([email])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([customerID])
  @@index([createdAt])
  @@map("contact_submissions")
}

model orders {
  id                  String       @id @default(uuid())
  lightspeedID        Int          @unique @map("lightspeed_id")
  vendorID            Int?         @map("vendor_id")
  orderedDate         String?      @map("order_date")
  receivedDate        String?      @map("received_date")
  arrivalDate         String?      @map("arival_date")
  refNum              String?      @map("ref_num")
  taxAmount           Float?       @map("tax_amount")
  totalCost           Float?       @map("total_cost")
  discount            Float?       @map("discount")
  totalDiscount       Float?       @map("total_discount")
  totalQuantity       Int?         @map("total_quantity")
  complete            Boolean      @default(false)
  noteID              Int?         @map("note_id")
  createdByID         Int?         @map("created_by_id")
  lightspeedCreatedAt DateTime?    @map("lightspeed_created_at")
  lightspeedUpdatedAt DateTime?    @map("lightspeed_updated_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at")
  archived            Boolean      @default(false)
  orderLines          orderLines[]
  vendor              vendors?     @relation(fields: [vendorID], references: [lightspeedID])

  @@index([vendorID])
  @@index([complete])
  @@index([orderedDate])
  @@index([lightspeedID])
  @@index([refNum])
  @@map("orders")
}

model orderLines {
  id                  String    @id @default(uuid())
  lightspeedID        Int?      @unique @map("lightspeed_id")
  orderID             Int       @map("order_id")
  itemID              Int?      @map("product_id")
  quantity            Int       @map("quantity")
  unitCost            Float     @map("unit_cost")
  discount            Float?    @default(0) @map("discount")
  lightspeedCreatedAt DateTime? @map("lightspeed_created_at")
  lightspeedUpdatedAt DateTime? @map("lightspeed_updated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  price               Float     @map("price")
  qtyReceived         Int?      @map("qty_received")
  total               Float     @map("total")
  order               orders    @relation(fields: [orderID], references: [lightspeedID], onDelete: Cascade)
  product             products? @relation(fields: [itemID], references: [lightspeedID])

  @@index([orderID])
  @@index([itemID])
  @@index([lightspeedID])
  @@map("order_lines")
}

model vendors {
  id                  Int       @id @default(autoincrement())
  lightspeedID        Int       @unique @map("lightspeed_id")
  companyName         String    @map("company_name")
  contactName         String?   @map("contact_name")
  email               String?   @map("email")
  phone               String?   @map("phone")
  address1            String?   @map("address1")
  address2            String?   @map("address2")
  city                String?   @map("city")
  state               String?   @map("state")
  zip                 String?   @map("zip")
  country             String?   @map("country")
  accountNumber       String?   @map("account_number")
  active              Boolean   @default(true)
  lightspeedCreatedAt DateTime? @map("lightspeed_created_at")
  lightspeedUpdatedAt DateTime? @map("lightspeed_updated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  orders              orders[]

  @@index([companyName])
  @@index([lightspeedID])
  @@index([active])
}

model restockNotifications {
  id         String             @id @default(uuid())
  itemID     Int                @map("item_id")
  customerID String?            @map("customer_id")
  status     NotificationStatus @default(PENDING) @map("status")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @default(now()) @updatedAt @map("updated_at")
  email      String             @map("email")
  firstName  String?            @map("first_name")
  lastName   String?            @map("last_name")
  customers  customers?         @relation(fields: [customerID], references: [id])
  products   products           @relation(fields: [itemID], references: [lightspeedID])

  @@index([itemID])
  @@index([customerID])
  @@index([status])
  @@index([createdAt])
  @@map("restock_notifications")
}

model images {
  id                  String          @id @default(uuid())
  lightspeedID        Int             @unique @map("lightspeed_id")
  description         String?
  filename            String
  ordering            Int             @default(0)
  publicID            String          @map("public_id")
  baseImageURL        String          @map("base_image_url")
  size                Int?
  itemID              Int?            @map("item_id")
  itemMatrixID        Int?            @map("item_matrix_id")
  lightspeedCreatedAt DateTime?       @map("lightspeed_created_at")
  lightspeedUpdatedAt DateTime?       @map("lightspeed_updated_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at")
  largeUrl            String?         @map("large_url")
  mediumUrl           String?         @map("medium_url")
  originalUrl         String?         @map("original_url")
  thumbnailUrl        String?         @map("thumbnail_url")
