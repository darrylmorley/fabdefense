model syncJobs {
  id          String        @id @default(uuid())
  entityType  EntityType    @map("entity_type")
  direction   SyncDirection
  status      SyncStatus    @default(PENDING)
  startedAt   DateTime      @default(now()) @map("started_at")
  completedAt DateTime?     @map("completed_at")
  totalItems  Int?          @map("total_items")
  processed   Int           @default(0)
  successful  Int           @default(0)
  failed      Int           @default(0)
  errors      Json?
  metadata    Json?
  syncType    SyncType?     @map("sync_type")
  syncRecords syncRecords[]

  @@index([entityType])
  @@index([status])
  @@index([startedAt])
  @@index([direction])
  @@map("sync_jobs")
}

model syncRecords {
  id             String        @id @default(uuid())
  syncJobId      String        @map("sync_job_id")
  entityType     EntityType    @map("entity_type")
  lightspeedId   Int           @map("lightspeed_id")
  localId        String?       @map("local_id")
  operation      String
  status         SyncStatus    @default(PENDING)
  direction      SyncDirection
  errorMessage   String?       @map("error_message")
  conflictData   Json?         @map("conflict_data")
  lastSyncedAt   DateTime      @default(now()) @map("last_synced_at")
  lightspeedHash String?       @map("lightspeed_hash")
  localHash      String?       @map("local_hash")
  retryCount     Int           @default(0) @map("retry_count")
  syncJob        syncJobs      @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@unique([syncJobId, lightspeedId, entityType])
  @@index([lightspeedId])
  @@index([entityType])
  @@index([status])
  @@index([lastSyncedAt])
  @@index([syncJobId])
  @@index([direction])
  @@map("sync_records")
}

model syncErrors {
  id           Int                 @id @default(autoincrement())
  syncJobId    String?             @map("sync_job_id")
  syncRecordId String?             @map("sync_record_id")
  entityType   EntityType          @map("entity_type")
  lightspeedId Int?                @map("lightspeed_id")
  localId      String?             @map("local_id")
  operation    SyncErrorOperation? @map("operation")
  errorType    ErrorType           @map("error_type")
  errorCode    String?             @map("error_code")
  errorMessage String              @map("error_message")
  stackTrace   String?             @map("stack_trace")
